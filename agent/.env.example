# ===== Required =====
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key_here
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ANTHROPIC_API_KEY=sk-ant-api03-...

# ===== Bot (Twilio WhatsApp) =====
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Public base URL of THIS backend. Locally = ngrok URL. In production = Render URL.
# Twilio webhook is configured as: {PUBLIC_URL}/webhook/twilio
PUBLIC_URL=https://your-backend.onrender.com

# ===== CORS (frontend that may call this API from the browser) =====
# Canonical Vercel deployment of the frontend:
FRONTEND_URL=https://your-frontend.vercel.app
# Optional extra origins, comma-separated (localhost dev ports are always allowed):
ALLOWED_ORIGINS=

# ===== Voice (ElevenLabs) =====
ELEVENLABS_API_KEY=sk_your_key
ELEVENLABS_VOICE_ID_ES=nTkjq09AuYgsNR8E4sDe

# ===== Bitso Business API =====
BITSO_API_KEY=your_bitso_key
BITSO_API_SECRET=your_bitso_secret
BITSO_API_BASE_URL=https://api-sandbox.bitso.com/api/v3

# ===== Optional =====
PORT=3001
ARBISCAN_API_KEY=your_arbiscan_key
