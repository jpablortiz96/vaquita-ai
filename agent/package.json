{
  "name": "@vaquita-ai/agent",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "VaquitaAI AI agent, orchestrator, and WhatsApp bot service",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:bot": "tsx watch src/server.ts",
    "boot": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:onchain": "RUN_ONCHAIN_TESTS=true vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@elevenlabs/elevenlabs-js": "^2.49.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.0",
    "@fastify/static": "^8.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "twilio": "^5.3.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
