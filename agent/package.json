{
  "name": "@vaquita-ai/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VaquitaAI AI agent and orchestrator service",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
